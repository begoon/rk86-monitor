FCF9: CA B2 FD                       jz      cursor_home
FCFC: FE 0D                          cpi     0Dh             ; ВК - возврат каретки
FCFE: CA F3 FD                       jz      carrage_return
FD01: FE 0A                          cpi     0Ah             ; ПС - перевод строки
FD03: CA 47 FD                       jz      new_line
FD06: FE 08                          cpi     8               ; Стрелка влево
FD08: CA D6 FD                       jz      move_left
FD0B: FE 18                          cpi     18h             ; Стрелка вправо
FD0D: CA B9 FD                       jz      move_right
FD10: FE 19                          cpi     19h             ; Стрелка вверх
FD12: CA E2 FD                       jz      move_up
FD15: FE 1A                          cpi     1Ah             ; Стрелка вниз
FD17: CA C5 FD                       jz      move_down
FD1A: FE 1B                          cpi     1Bh             ; АР2
FD1C: CA 9E FD                       jz      ap2_seq_start
FD1F: FE 07                          cpi     7               ; Звуковой сигнал
FD21: C2 38 FD                       jnz     print_char      ; Нет -> печатный символ

                    ; Звуковой сигнал (B = высота тона, C = длительность)
FD24: 01 F0 05                       lxi     b, beep

                    ;----------------------------------------------------------------------------
                    ; Подпрограмма звукового сигнала.
                    ;   B - задержка периода (высота тона)
                    ;   C - количество периодов (длительность)
                    ; Звук формируется сменой уровня на выходе INTE процессора
                    ; командами EI (высокий) и DI (низкий).
                    ;   Формулы: b = 47/f(кГц), c = t(мс)/(b*0.021)
                    ;   Диапазон частот: 184Гц - 47кГц
                    ;----------------------------------------------------------------------------
FD27:               sound:                                   ; FD27
FD27: 78                             mov     a, b
FD28:               sound_on_loop:                           ; FD28
FD28: FB                             ei                      ; Верхний полупериод
FD29: 3D                             dcr     a
FD2A: C2 28 FD                       jnz     sound_on_loop

FD2D: 78                             mov     a, b
FD2E:               sound_off_loop:                          ; FD2E
FD2E: F3                             di                      ; Нижний полупериод
FD2F: 3D                             dcr     a
FD30: C2 2E FD                       jnz     sound_off_loop
FD33: 0D                             dcr     c
FD34: C2 27 FD                       jnz     sound
FD37: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Печать символа на экран и перемещение курсора
                    ;----------------------------------------------------------------------------
FD38:               print_char:                              ; FD38
FD38: 71                             mov     m, c            ; Выводим символ в видео ОЗУ
FD39: CD B9 FD                       call    move_right      ; Перемещаем курсор вправо
                    ; Если курсор вернулся в начало экрана -> скроллинг
FD3C: 7A                             mov     a, d
FD3D: FE 03                          cpi     3               ; Верхняя строка?
FD3F: C0                             rnz
FD40: 7B                             mov     a, e
FD41: FE 08                          cpi     8               ; Первая позиция?
FD43: C0                             rnz
FD44: CD E2 FD                       call    move_up         ; Переходим на нижнюю строку

                    ;----------------------------------------------------------------------------
                    ; Перевод строки (ПС).
                    ; Если курсор в нижней строке -> скроллинг экрана вверх на 1 строку.
                    ;----------------------------------------------------------------------------
FD47:               new_line:                                  ; FD47
FD47: 7A                             mov     a, d
FD48: FE 1B                          cpi     1Bh             ; 3+25-1 = самая нижняя строка
FD4A: C2 C5 FD                       jnz     move_down       ; Нет -> просто вниз
FD4D: E5                             push    h
FD4E: D5                             push    d

                    ; Смещение экрана на 1 строку вверх
FD4F: 21 C2 77                       lxi     h, video_memory+(78*3)+8   ; Начало 1-й видимой строки
FD52: 11 10 78                       lxi     d, video_memory+(78*4)+8   ; Начало 2-й видимой строки
FD55: 01 9E 07                       lxi     b, 25*78                   ; 25 строк по 78 символов

FD58:               scroll_loop:                             ; FD58
FD58: 1A                             ldax    d
FD59: 77                             mov     m, a
FD5A: 23                             inx     h
FD5B: 13                             inx     d
FD5C: 0B                             dcx     b
FD5D: 79                             mov     a, c
FD5E: B0                             ora     b
FD5F: C2 58 FD                       jnz     scroll_loop

FD62: D1                             pop     d
FD63: E1                             pop     h
FD64: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Обработка 1-го байта АР2-последовательности (должен быть "Y")
                    ;----------------------------------------------------------------------------
FD65:               ap2_byte_1:                                   ; FD65
FD65: 79                             mov     a, c
FD66: FE 59                          cpi     'Y'
FD68: C2 E9 FC                       jnz     reset_ap2_seq        ; Не "Y" -> сброс АР2
FD6B: CD B2 FD                       call    cursor_home
FD6E: 3E 02                          mvi     a, 2            ; Ожидаем 2-й байт
FD70: C3 EA FC                       jmp     update_ap2_and_exit

                    ;----------------------------------------------------------------------------
                    ; Обработка 2-го байта АР2-последовательности (смещение по Y + 20h)
                    ;----------------------------------------------------------------------------
FD73:               ap2_byte_2:                                  ; FD73
FD73: 79                             mov     a, c
FD74: D6 20                          sui     20h             ; Действительное смещение по Y
FD76: 4F                             mov     c, a

FD77:               ap2_move_y_loop:                         ; FD77
FD77: 0D                             dcr     c
FD78: 3E 04                          mvi     a, 4                ; Признак для следующего этапа
FD7A: FA EA FC                       jm      update_ap2_and_exit ; Все -> ожидаем 3-й байт (X)
FD7D: C5                             push    b
FD7E: CD C5 FD                       call    move_down
FD81: C1                             pop     b
FD82: C3 77 FD                       jmp     ap2_move_y_loop

                    ;----------------------------------------------------------------------------
                    ; Сохранение параметров курсора и выход из entry_putc
                    ;----------------------------------------------------------------------------
FD85:               set_cursor_and_exit:                        ; FD85
FD85: 22 00 76                       shld    cursor_addr
FD88: EB                             xchg
FD89: 22 02 76                       shld    cursor_xy
                    ; Передаем координаты курсора контроллеру ВГ75
FD8C: 3E 80                          mvi     a, 80h          ; Команда "установить курсор"
FD8E: 32 01 C0                       sta     vg75_cmd_reg
FD91: 7D                             mov     a, l            ; Координата X
FD92: 32 00 C0                       sta     vg75_params
FD95: 7C                             mov     a, h            ; Координата Y
FD96: 32 00 C0                       sta     vg75_params
FD99: E1                             pop     h
FD9A: D1                             pop     d
FD9B: C1                             pop     b
FD9C: F1                             pop     psw
FD9D: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Начало АР2-последовательности
                    ; Был прочитан код символа АР2, необходимо прочитать АР2 последовательность.
                    ; Реализована только одна АР2 последовательность:
                    ; Установка курсора в заданные координаты АР2+'Y'+(x+20h)+(y+20h):
                    ;   где  x - номер позиции в строке (0 - 63),
                    ;        y - номер строки (0 - 24).
                    ; Отсчет начинается с верхнего левого угла экрана.
                    ;----------------------------------------------------------------------------
FD9E:               ap2_seq_start:                             ; FD9E
FD9E: 3E 01                          mvi     a, 1              ; Ожидаем 1-й байт
FDA0: C3 EA FC                       jmp     update_ap2_and_exit

                    ;----------------------------------------------------------------------------
                    ; Инициализация дисплея (СТР).
                    ; Обработка управляющего символа инициализации дисплея СТР.
                    ; Очистка видео ОЗУ и установка курсора в начало.
                    ; Выполняются следующие действия:
                    ;   - вся экранная область ОЗУ (2342 байта) обнуляется,
                    ;   - курсор устанавливается в нулевую позицию.
                    ;  Очистка начинается с конечного адреса видео ОЗУ, с нижнего правого угла экрана.
                    ;----------------------------------------------------------------------------
FDA3:               clear_screen:                                ; FDA3
FDA3: 21 F4 7F                       lxi     h, video_memory_end
FDA6: 11 25 09                       lxi     d, video_mem_size+1

FDA9:               clear_screen_loop:                           ; FDA9
FDA9: AF                             xra     a
FDAA: 77                             mov     m, a
FDAB: 2B                             dcx     h
FDAC: 1B                             dcx     d
FDAD: 7B                             mov     a, e
FDAE: B2                             ora     d
FDAF: C2 A9 FD                       jnz     clear_screen_loop

                    ;----------------------------------------------------------------------------
                    ; Установка курсора в начальную позицию (верхний левый угол).
                    ; Реально: позиция X=8, Y=3 (с учетом служебных строк и отступа).
                    ;----------------------------------------------------------------------------
FDB2:               cursor_home:                           ; FDB2
FDB2: 11 08 03                       lxi     d, 308h
FDB5: 21 C2 77                       lxi     h, video_memory+(78*3)+8
FDB8: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Перемещение курсора вправо на одну позицию
                    ;----------------------------------------------------------------------------
FDB9:               move_right:                           ; FDB9
FDB9: 7B                             mov     a, e
FDBA: 23                             inx     h               ; Адрес в видео ОЗУ += 1
FDBB: 1C                             inr     e               ; Позиция X += 1
FDBC: FE 47                          cpi     8+64-1          ; Правая граница? (71)
FDBE: C0                             rnz
FDBF: 1E 08                          mvi     e, 8            ; Переход на левый край
FDC1: 01 C0 FF                       lxi     b, -64          ; Отмотка адреса
FDC4: 09                             dad     b

                    ;----------------------------------------------------------------------------
                    ; Перемещение курсора вниз на одну строку
                    ;----------------------------------------------------------------------------
FDC5:               move_down:                               ; FDC5
FDC5: 7A                             mov     a, d
FDC6: FE 1B                          cpi     1Bh             ; 3+25-1 = нижняя строка
FDC8: 01 4E 00                       lxi     b, 78           ; Смещение: +1 строка
FDCB: C2 D3 FD                       jnz     move_down_skip
FDCE: 16 02                          mvi     d, 2            ; Переход на верхнюю строку (будет 3)
FDD0: 01 B0 F8                       lxi     b, -24*78       ; Смещение наверх

FDD3:               move_down_skip:                          ; FDD3
FDD3: 14                             inr     d
FDD4: 09                             dad     b
FDD5: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Перемещение курсора влево на одну позицию
                    ;----------------------------------------------------------------------------
FDD6:               move_left:                               ; FDD6
FDD6: 7B                             mov     a, e
FDD7: 2B                             dcx     h
FDD8: 1D                             dcr     e
FDD9: FE 08                          cpi     8               ; Левая граница?
FDDB: C0                             rnz
FDDC: 1E 47                          mvi     e, 8+64-1       ; Переход на правый край (71)
FDDE: 01 40 00                       lxi     b, 64
FDE1: 09                             dad     b

                    ;----------------------------------------------------------------------------
                    ; Перемещение курсора вверх на одну строку
                    ;----------------------------------------------------------------------------
FDE2:               move_up:                                 ; FDE2
FDE2: 7A                             mov     a, d
FDE3: FE 03                          cpi     3               ; Верхняя строка?
FDE5: 01 B2 FF                       lxi     b, -78          ; Смещение: -1 строка
FDE8: C2 F0 FD                       jnz     move_up_skip
FDEB: 16 1C                          mvi     d, 1Bh+1        ; Переход на нижнюю строку (будет 1Bh)
FDED: 01 50 07                       lxi     b, 24*78        ; Смещение вниз

FDF0:               move_up_skip:                            ; FDF0
FDF0: 15                             dcr     d
FDF1: 09                             dad     b
FDF2: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Возврат каретки (ВК). Курсор в начало текущей строки.
                    ;----------------------------------------------------------------------------
FDF3:               carrage_return:                                  ; FDF3
FDF3: 7D                             mov     a, l
FDF4: 93                             sub     e               ; Вычитаем позицию в строке
FDF5: D2 F9 FD                       jnc     carrage_return_borrow
FDF8: 25                             dcr     h               ; Заем из старшего байта

FDF9:               carrage_return_borrow:                   ; FDF9
FDF9: 6F                             mov     l, a
FDFA: 1E 08                          mvi     e, 8            ; Первая позиция
FDFC: 01 08 00                       lxi     b, 8
FDFF: 09                             dad     b
FE00: C9                             ret

                    ;============================================================================
                    ; Опрос состояния клавиатуры.
                    ;   Выход: A = FFh - клавиша нажата, A = 0 - не нажата.
                    ; Реализует автоповтор и устранение дребезга контактов.
                    ;   Счетчик обращений:
                    ;     21          - устранение дребезга
                    ;     21+224      - начальная задержка автоповтора
                    ;     21+224+64*N - стандартный период автоповтора
                    ; Стандартная задержка между обращениями к подпрограмме составляет 31 такт.
                    ;============================================================================
FE01:               entry_kbhit:                             ; FE01
                    ; Проверка на нажатие [РУС/ЛАТ]
FE01: 3A 02 80                       lda     vv55_port_c
FE04: E6 80                          ani     80h
FE06: CA 0E FE                       jz      ruslat_not_pressed  ; Отпущена -> продолжаем
FE09: 3A 05 76                       lda     pressed_key         ; Если нажата и ранее была нажата
FE0C: B7                             ora     a                   ; другая клавиша,
FE0D: C0                             rnz                         ; то выходим

FE0E:               ruslat_not_pressed:                          ; FE0E
FE0E: E5                             push    h
FE0F: 2A 09 76                       lhld    keyboard_repeat  ; Параметры автоповтора (L=код, H=счетчик)
FE12: CD 72 FE                       call    entry_scan_kbd   ; Получить код клавиши
                                                              ;   FFh - не нажата
                                                              ;   FEh - [РУС/ЛАТ]
                                                              ;   xx  - код символа
FE15: BD                             cmp     l                ; Та же клавиша?
FE16: 6F                             mov     l, a
FE17: CA 2A FE                       jz      keyboard_retention        ; Да -> удержание

                    ; Клавиша отпущена или нажата другая
FE1A:               release_ruslat:                          ; FE1A
FE1A: 3E 01                          mvi     a, 1
FE1C: 32 0B 76                       sta     released        ; Признак отпускания
FE1F: 26 15                          mvi     h, bounce       ; Задержка дребезга (21)

FE21:               not_pr_exit:                             ; FE21
FE21: AF                             xra     a               ; Клавиша не нажата

FE22:               entry_kbhit_exit:                        ; FE22
FE22: 22 09 76                       shld    keyboard_repeat
FE25: E1                             pop     h
FE26: 32 05 76                       sta     pressed_key
FE29: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Обработка удержания клавиши
                    ;----------------------------------------------------------------------------
FE2A:               keyboard_retention:                        ; FE2A
FE2A: 25                             dcr     h                 ; Счетчик задержки--
FE2B: C2 21 FE                       jnz     not_pr_exit       ; Время не вышло -> не нажата
FE2E: 3C                             inr     a                 ; A = FFh?
FE2F: CA 22 FE                       jz      entry_kbhit_exit  ; Клавиша не нажата -> выход
FE32: 3C                             inr     a                 ; A = FEh?
FE33: CA 51 FE                       jz      process_ruslat    ; [РУС/ЛАТ] -> обработать

                    ; Нажата клавиша
FE36: C5                             push    b
FE37: 01 03 50                       lxi     b, kb_click     ; Щелчок нажатия
FE3A: CD 27 FD                       call    sound
FE3D: C1                             pop     b

FE3E: 3A 0B 76                       lda     released
FE41: 26 E0                          mvi     h, first_kb_delay ; Начальная задержка (224)
FE43: 3D                             dcr     a
FE44: 32 0B 76                       sta     released
FE47: CA 4C FE                       jz      keyboard_first_press       ; Первое нажатие -> начальная задержка
FE4A: 26 40                          mvi     h, regular_kb_delay ; Автоповтор -> стандартная (64)

FE4C:               keyboard_first_press:                               ; FE4C
FE4C: 3E FF                          mvi     a, 0FFh         ; Признак: клавиша нажата
FE4E: C3 22 FE                       jmp     entry_kbhit_exit

                    ;----------------------------------------------------------------------------
                    ; Обработка клавиши [РУС/ЛАТ]
                    ; Бесконечный цикл ожидания отпускания, затем инверсия флага.
                    ;----------------------------------------------------------------------------
FE51:               process_ruslat:                              ; FE51
FE51: 3A 02 80                       lda     vv55_port_c
FE54: E6 80                          ani     80h
FE56: CA 51 FE                       jz      process_ruslat      ; Ждем отпускания

FE59: 3A 06 76                       lda     ruslat_flag     ; Инверсия флага РУС/ЛАТ
FE5C: 2F                             cma
FE5D: 32 06 76                       sta     ruslat_flag
FE60: C3 1A FE                       jmp     release_ruslat

                    ;============================================================================
                    ; Ввод символа с клавиатуры.
                    ;   Выход: A - введенный символ.
                    ; Ожидает нажатия клавиши в бесконечном цикле.
                    ;============================================================================
FE63:               entry_getc:                              ; FE63
FE63: CD 01 FE                       call    entry_kbhit
FE66: B7                             ora     a
FE67: CA 63 FE                       jz      entry_getc      ; Не нажата -> ждем

FE6A: AF                             xra     a
FE6B: 32 05 76                       sta     pressed_key     ; Сбрасываем признак нажатия
FE6E: 3A 09 76                       lda     keyboard_repeat ; Код клавиши
FE71: C9                             ret

                    ;============================================================================
                    ; Сканирование матрицы клавиатуры 8x8.
                    ;   Выход: A = FFh  - не нажата
                    ;          A = FEh  - [РУС/ЛАТ]
                    ;          A = код  - код символа
                    ;============================================================================
FE72:               entry_scan_kbd:                          ; FE72
                    ; Проверка [РУС/ЛАТ]
FE72: 3A 02 80                       lda     vv55_port_c
FE75: E6 80                          ani     80h
FE77: C2 7D FE                       jnz     fast_kbd_contrl
FE7A: 3E FE                          mvi     a, 0FEh         ; Код [РУС/ЛАТ]
FE7C: C9                             ret

                    ; Быстрая проверка: нажата ли хоть одна клавиша?
FE7D:               fast_kbd_contrl:                         ; FE7D
FE7D: AF                             xra     a
FE7E: 32 00 80                       sta     vv55_port_a      ; Все линии сканирования = 0
FE81: 32 02 80                       sta     vv55_port_c      ; Погасить светодиод
FE84: 3A 06 76                       lda     ruslat_flag     ; Управление светодиодом РУС/ЛАТ
FE87: E6 01                          ani     1
FE89: F6 06                          ori     6               ; Команда: зажечь/погасить
FE8B: 32 03 80                       sta     vv55_ctrl
FE8E: 3A 01 80                       lda     vv55_port_b      ; Читаем состояние матрицы
FE91: 3C                             inr     a               ; Если хоть одна нажата, A != FFh
FE92: C2 97 FE                       jnz     key_is_pressed
FE95: 3D                             dcr     a               ; FFh = не нажата
FE96: C9                             ret

                    ; Сканирование матрицы клавиатуры
                    ;--------------------------------------------------------------------
                    ; Таблица скан-кодов клавиатуры РК:
                    ;  Столбец:   0    1     2     3     4     5     6     7
                    ;  Клавиша
                    ;  в столбце:
                    ;      0:     ↖︎    ТАБ   0     8     Ю     Х     П     Ь
                    ;      1:    СТР   ПС    1     9     А     И     Я     Ы
                    ;      2:    AP2   ВК    2     :     Б     Й     Р     З
                    ;      3:    F1    ЗБ    3     ;     Ц     К     С     Ш
                    ;      4:    F2    <-    4     ,     Д     Л     Т     Э
                    ;      5:    F3    ^     5     -     Е     М     У     Щ
                    ;      6:    F4    ->    6     .     Ф     Н     Ж     Ч
                    ;      7:    F5    v     7     /     Г     О     В     пробел
                    ;--------------------------------------------------------------------
                    ; Для столбцов 0 и 1 скан коды одинаковы потому, что перекодировка
                    ; происходит табличным способом в отдельных ветках для каждого столбца.
                    ; В столбцах 2 - 7 к номеру клавиши: 00SSSNNNb, где SSS - номер столбца,
                    ; NNN - номер клавиши, прибавляется 20h, чтобы упростить декодирование.

FE97:               key_is_pressed:                            ; FE97
FE97: E5                             push    h
FE98: 2E 01                          mvi     l, 1            ; Бегущая единица для сканирования
FE9A: 26 07                          mvi     h, 8-1          ; Количество столбцов

                    ; Цикл сканирования столбцов
FE9C:               scan_kbd_loop:                           ; FE9C
FE9C: 7D                             mov     a, l
FE9D: 0F                             rrc
FE9E: 6F                             mov     l, a
FE9F: 2F                             cma
FEA0: 32 00 80                       sta     vv55_port_a     ; Активируем столбец
FEA3: 3A 01 80                       lda     vv55_port_b     ; Читаем строки
FEA6: 2F                             cma
FEA7: B7                             ora     a
FEA8: C2 B3 FE                       jnz     scan_bounce     ; Есть нажатие -> устранение дребезга
FEAB: 25                             dcr     h
FEAC: F2 9C FE                       jp      scan_kbd_loop   ; Следующий столбец

                    ; Клавиша не нажата (или дребезг)
FEAF:               key_not_press:                           ; FEAF
FEAF: 3E FF                          mvi     a, 0FFh
FEB1: E1                             pop     h
FEB2: C9                             ret

                    ; Устранение дребезга: 32 повторных опроса
FEB3:               scan_bounce:                             ; FEB3
FEB3: 2E 20                          mvi     l, 32

FEB5:               scan_boun_loop:                          ; FEB5
FEB5: 3A 01 80                       lda     vv55_port_b
FEB8: 2F                             cma
FEB9: B7                             ora     a
FEBA: CA AF FE                       jz      key_not_press   ; Не подтвердилось -> не нажата
FEBD: 2D                             dcr     l
FEBE: C2 B5 FE                       jnz     scan_boun_loop

FEC1: 2E 08                          mvi     l, 8            ; Количество клавиш в столбце

                    ; Определение номера клавиши (из позиционного кода в порядковый)
                    ; Цикл определения номера клавиши в столбце
                    ; Здесь из позиционного кода, считанного с порта B D20, мы
                    ; получаем номер клавиши в столбце (начиная со старших номеров).
FEC3:               num_kbd_loop:                            ; FEC3
FEC3: 2D                             dcr     l
FEC4: 07                             rlc
FEC5: D2 C3 FE                       jnc     num_kbd_loop    ; Сдвигаем пока не найдем нажатую

FEC8: 7C                             mov     a, h            ; H <-> L (H = номер клавиши,
FEC9: 65                             mov     h, l            ; L = номер столбца)
FECA: 6F                             mov     l, a

                    ; Столбцы 0 и 1 - управляющие клавиши (перекодировка по таблице)
                    ; Колонки 0 и 1 это управляющие символы, используемые в стандартных
                    ; дисплеях. Для перекодировки используются специальные таблицы.
FECB: FE 01                          cpi     1               ; Столбец 1?
FECD: CA FA FE                       jz      make_1_column
FED0: DA F3 FE                       jc      make_0_column   ; Столбец 0?

                    ; Остальные клавиши используются для ввода отображаемых символов.
                    ; Столбцы 2-7: код = столбец*8 + 20h + номер клавиши
FED3: 07                             rlc
FED4: 07                             rlc
FED5: 07                             rlc
FED6: C6 20                          adi     20h
FED8: B4                             ora     h               ; Прибавляем номер клавиши
FED9: FE 5F                          cpi     5Fh             ; Пробел?
FEDB: C2 06 FF                       jnz     scan_others
FEDE: 3E 20                          mvi     a, 20h          ; Код пробела
FEE0: E1                             pop     h
FEE1: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Таблицы перекодировки управляющих клавиш
                    ;----------------------------------------------------------------------------
                    ; Столбец 1 (клавиши 0-7):
FEE2: 09            table_column_1:  db 9                    ; FEE2 - ТАБ
FEE3: 0A                             db 0Ah                  ; ПС
FEE4: 0D                             db 0Dh                  ; ВК
FEE5: 7F                             db 7Fh                  ; ЗБ
FEE6: 08                             db 8                    ; Стрелка влево
FEE7: 19                             db 19h                  ; Стрелка вверх
FEE8: 18                             db 18h                  ; Стрелка вправо
FEE9: 1A                             db 1Ah                  ; Стрелка вниз

                    ; Столбец 0 (клавиши 0-8):
FEEA: 0C            table_column_0:  db 0Ch                  ; FEEA - Курсор в начало (↖︎)
FEEB: 1F                             db 1Fh                  ; СТР
FEEC: 1B                             db 1Bh                  ; АР2
FEED: 00                             db 0                    ; F1
FEEE: 01                             db 1                    ; F2
FEEF: 02                             db 2                    ; F3
FEF0: 03                             db 3                    ; F4
FEF1: 04                             db 4                    ; F5 (нет на клавиатуре)
FEF2: 05                             db 5                    ; (не используется)

                    ; Перекодировка столбца 0
FEF3:               make_0_column:                           ; FEF3
FEF3: 7C                             mov     a, h
FEF4: 21 EA FE                       lxi     h, table_column_0
FEF7: C3 FE FE                       jmp     scan_table

                    ; Перекодировка столбца 1
FEFA:               make_1_column:                           ; FEFA
FEFA: 7C                             mov     a, h
FEFB: 21 E2 FE                       lxi     h, table_column_1

FEFE:               scan_table:                              ; FEFE
FEFE: 85                             add     l               ; Индекс в таблице
FEFF: 6F                             mov     l, a
FF00: 7E                             mov     a, m            ; Код из таблицы
FF01: FE 40                          cpi     40h             ; Управляющая клавиша?
FF03: E1                             pop     h
FF04: D8                             rc                      ; Да -> выход

FF05: E5                             push    h

                    ;----------------------------------------------------------------------------
                    ; Обработка клавиш с модификаторами [УС], [СС] и режимом РУС/ЛАТ.
                    ; Скан-код в L, состояние вспомогательных клавиш в H.
                    ; Здесь происходит выдача кода для всех клавиш, кроме управляющих, [ЗБ] и пробела.
                    ; Эти клавиши выдают 1 из 2-х символов в зависимости от состояния клавиш [СС], [УС]
                    ; и режима рус/лат. Скан код клавиши находится в L, состояние клавиш [СС] и [УС] в H.
                    ;----------------------------------------------------------------------------
FF06:               scan_others:                              ; FF06
FF06: 6F                             mov     l, a
FF07: 3A 02 80                       lda     vv55_port_c      ; Читаем модификаторы
FF0A: 67                             mov     h, a
FF0B: E6 40                          ani     40h             ; [УС] нажата?
FF0D: C2 1A FF                       jnz     rus_or_lat      ; Нет -> проверяем РУС/ЛАТ

                    ; Клавиша [УС]: буквы (40h-5Fh) -> управляющие коды (00h-1Fh)
                    ; Обслуживание модификационной клавиши [УС].
                    ; Она работает только с буквенными клавишами с кодом 40h - 5Fh.
                    ; Если нажата одна из этих клавиш в сочетании с [УС], то
                    ; выдается код на 30h меньше, т.е. 00h-1Fh (управляющие коды)
                    ; Признак рус/лат на управляющие коды не влияет.
FF10: 7D                             mov     a, l
FF11: FE 40                          cpi     40h
FF13: FA 3F FF                       jm      not_press_us_ss  ; Не буква -> пропускаем
FF16: E6 1F                          ani     1Fh             ; Обнуляем старшие биты
FF18: E1                             pop     h
FF19: C9                             ret

                    ; Режим РУС/ЛАТ: буквы переводятся в русский регистр (+20h)
                    ; Выдача кода в зависимости от состояния рус/лат
                    ; Действует только на буквенные клавиши со кодом  40h - 5Fh.
                    ; Если признак рус/лат в состоянии лат (=0), то скан код = код.
                    ; Если рус/лат = рус (=0FFh), то код больше от скан кода на 20h.
FF1A:               rus_or_lat:                              ; FF1A
FF1A: 3A 06 76                       lda     ruslat_flag
FF1D: B7                             ora     a
FF1E: CA 2A FF                       jz      scan_ss         ; ЛАТ -> без изменений
FF21: 7D                             mov     a, l
FF22: FE 40                          cpi     40h
FF24: FA 2A FF                       jm      scan_ss         ; Не буква -> без изменений
FF27: F6 20                          ori     20h             ; Перевод в русский регистр
FF29: 6F                             mov     l, a

                    ; Клавиша [СС]: буквы меняют раскладку, символы - верхний/нижний регистр
                    ; Обслуживание модификационной клавиши [СС].
                    ; Действие клавиши зависит от назначения (кода) клавиши.
                    ; Буквенные клавиши меняют раскладку рус <-> лат
                    ; Символьные и цифровые клавиши выдают один из 2-х символов
                    ; которые она обозначает.
FF2A:               scan_ss:                                  ; FF2A
FF2A: 7C                             mov     a, h
FF2B: E6 20                          ani     20h              ; [СС] нажата?
FF2D: C2 3F FF                       jnz     not_press_us_ss  ; Нет -> выход
FF30: 7D                             mov     a, l
FF31: FE 40                          cpi     40h
FF33: FA 3B FF                       jm      not_pressed_ss   ; Символ/цифра
FF36: 7D                             mov     a, l
FF37: EE 20                          xri     20h              ; Буква: лат <-> рус
FF39: E1                             pop     h
FF3A: C9                             ret

                    ; Если модификационные клавиши УС и СС не нажаты
FF3B:               not_pressed_ss:                           ; FF3B
FF3B: 7D                             mov     a, l             ; Цифры/символы: сбрасываем бит
FF3C: E6 2F                          ani     2Fh
FF3E: 6F                             mov     l, a

                    ; Модификаторы не нажаты
FF3F:               not_press_us_ss:                          ; FF3F
FF3F: 7D                             mov     a, l
FF40: FE 40                          cpi     40h              ; Буква?
FF42: E1                             pop     h
FF43: F0                             rp                       ; Да -> выход

                    ; Если модификационные клавиши УС и СС не нажаты
                    ; Обработка цифровых и символьных клавиш.
FF44: E5                             push    h
FF45: 6F                             mov     l, a            ; сохранить код в L
FF46: E6 0F                          ani     0Fh             ; сбрасываем ненужные биты
FF48: FE 0C                          cpi     0Ch             ; для клавиш с кодом
FF4A: 7D                             mov     a, l            ; 20h - 2Ch и 30h - 3Ch
FF4B: FA 50 FF                       jm      not_high        ; меняются местами
FF4E: EE 10                          xri     10h

FF50:               not_high:                                ; FF50
FF50: E1                             pop     h
FF51: C9                             ret

                    ;============================================================================
                    ; Определение верхней границы свободной памяти.
                    ; Используется для программ с большими буферами (например, текстовых).
                    ; Если в ОЗУ необходимо разместить какую либо программу (резидентную или
                    ; драйвер), ее размещают в верхней области (ниже служебной области Монитора),
                    ; а границу верхней свободной памяти устанавливают на байт ниже.
                    ; Это предотвратит затирание кода программы растущим буфером.
                    ;============================================================================
FF52:               entry_getlim:                            ; FF52
FF52: 2A 31 76                       lhld    memory_limit
FF55: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Установка верхней границы свободной памяти
                    ;----------------------------------------------------------------------------
FF56:               entry_setlim:                            ; FF56
FF56: 22 31 76                       shld    memory_limit
FF59: C9                             ret

                    ;============================================================================
                    ; Строковые константы (завершаются нулевым байтом)
                    ;============================================================================

                    ; Начальное сообщение при включении
FF5A: 1F 72 61 64   radio_prompt:    db 1Fh, "radio-86rk", 0  ; FF5A
FF5E: 69 6F 2D 38
FF62: 36 72 6B 00

                    ; Промт: готовность к вводу команды
FF66: 0D 0A         prompt:          dw 0A0Dh                 ; FF66
FF68: 2D 2D 3E 00                    db "-->", 0

                    ; Отступ для вывода адреса с новой строки (ВК, ПС, 4x стрелка вправо)
FF6C: 0D 0A         next_line_prefix: dw 0A0Dh                 ; FF6C
FF6E: 18 18 18 18                    db 18h, 18h, 18h, 18h, 0
FF72: 00

                    ; Имена регистров для команды X (с возвратом курсора на 6 строк вверх)
FF73: 0D 0A         registers:       dw 0A0Dh                 ; FF73
FF75: 20 50 43 2D                    db " PC-"
FF79: 0D 0A                          dw 0A0Dh
FF7B: 20 48 4C 2D                    db " HL-"
FF7F: 0D 0A                          dw 0A0Dh
FF81: 20 42 43 2D                    db " BC-"
FF85: 0D 0A                          dw 0A0Dh
FF87: 20 44 45 2D                    db " DE-"
FF8B: 0D 0A                          dw 0A0Dh
FF8D: 20 53 50 2D                    db " SP-"
FF91: 0D 0A                          dw 0A0Dh
FF93: 20 41 46 2D                    db " AF-"
FF97: 19 19 19 19                    db 19h, 19h, 19h, 19h, 19h, 19h, 0
FF9B: 19 19 00

                    ; Затирание предыдущего символа (backspace, пробел, backspace)
FF9E: 08 20 08 00   back_clear:      db 8, 20h, 8, 0          ; FF9E

                    ;============================================================================
                    ; Адрес возврата из отлаживаемой программы.
                    ; Выполняется при срабатывании RST 6, установленной командой G.
                    ; Сохраняет регистры в служебных ячейках (доступны по команде X)
                    ; и выводит на экран адрес останова.
                    ; Содержимое регистров сохраняется в служебных ячейках Монитора.
                    ; В последствии его можно просмотреть командой X Монитора.
                    ; На экран выдается адрес останова. И управление передается на
                    ; "горячий" старт Монитора (prompt_loop).
                    ;============================================================================
FFA2:               return_address:                          ; FFA2
FFA2: 22 16 76                       shld    hl_storage
FFA5: F5                             push    psw
FFA6: E1                             pop     h
FFA7: 22 1E 76                       shld    af_storage

                    ; Реальный адрес останова (из стека, на 1 больше из-за RST 6)
                    ; Возвращаем из стека реальный адрес останова, он может отличаться от
                    ; указанного в команде G. Он сохраняется в стеке, поскольку мы
                    ; используем команду RST 6, и больше на 1.
FFAA: E1                             pop     h
FFAB: 2B                             dcx     h
FFAC: 22 14 76                       shld    pc_storage

                    ; Сохраняем остальные регистры через SP
                    ; Через HL получаем значение указателя стека и используя последний
                    ; сохраняем значения всех остальных регистров
FFAF: 21 00 00                       lxi     h, 0
FFB2: 39                             dad     sp
FFB3: 31 1E 76                       lxi     sp, sp_storage+2
FFB6: E5                             push    h               ; SP
FFB7: D5                             push    d               ; DE
FFB8: C5                             push    b               ; BC

FFB9: 2A 14 76                       lhld    pc_storage
FFBC: 31 CF 76                       lxi     sp, stack_bottom
FFBF: CD 78 FB                       call    print_addr_from_hl ; Выводим адрес останова

                    ; Проверяем: совпадает ли реальный адрес с заданным в команде G?
                    ; Если они равны, восстанавливаем значение байта по этому адресу,
                    ; сохраненное ранее командой G.
FFC2: EB                             xchg
FFC3: 2A 23 76                       lhld    stop_addr
FFC6: CD 90 F9                       call    cmp_hl_de
FFC9: C2 6C F8                       jnz     prompt_loop     ; Не совпадает -> промт

                    ; Восстанавливаем байт по адресу останова
FFCC: 3A 25 76                       lda     stop_addr_value
FFCF: 77                             mov     m, a
FFD0: C3 6C F8                       jmp     prompt_loop

                    ;============================================================================
                    ; Команда X. Просмотр и изменение регистров процессора.
                    ; Выводит содержимое регистровых пар (PC, HL, BC, DE, SP, AF)
                    ; из служебных ячеек с возможностью изменения.
                    ;============================================================================
FFD3:               print_regs:                              ; FFD3
FFD3: 21 73 FF                       lxi     h, registers
FFD6: CD 22 F9                       call    entry_puts
FFD9: 21 14 76                       lxi     h, pc_storage
FFDC: 06 06                          mvi     b, 6            ; 6 регистровых пар

FFDE:               print_regs_loop:                         ; FFDE
FFDE: 5E                             mov     e, m            ; Содержимое
FFDF: 23                             inx     h               ; регистровой пары
FFE0: 56                             mov     d, m            ; в DE
FFE1: C5                             push    b
FFE2: E5                             push    h
FFE3: EB                             xchg
FFE4: CD 78 FB                       call    print_addr_from_hl ; Выводим значение
FFE7: CD EE F8                       call    input_string       ; Ввод нового значения
FFEA: D2 F6 FF                       jnc     regs_not_changed   ; Ничего не введено

FFED: CD 5A F9                       call    parse_hex          ; Новое значение в HL
FFF0: D1                             pop     d
FFF1: D5                             push    d
FFF2: EB                             xchg
FFF3: 72                             mov     m, d               ; Сохраняем
FFF4: 2B                             dcx     h
FFF5: 73                             mov     m, e

FFF6:               regs_not_changed:                           ; FFF6
FFF6: E1                             pop     h
FFF7: C1                             pop     b
FFF8: 05                             dcr     b
FFF9: 23                             inx     h
FFFA: C2 DE FF                       jnz     print_regs_loop
FFFD: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Неиспользуемые 2 байта в конце ПЗУ.
                    ; В журнале "Радио" №8 1986г.: FFFFh
                    ; В книге "Домашний компьютер" МРБ: 89BBh
                    ;----------------------------------------------------------------------------
FFFE: FF FF                          dw 0FFFFh

                                     end

