                    ;============================================================================
                    ; Монитор компьютера Радио-86РК (ПЗУ 2кБ)
                    ;============================================================================

                    ;----------------------------------------------------------------------------
                    ; Адреса регистров периферийных БИС
                    ;----------------------------------------------------------------------------

                    ; ППА К580ВВ55 D20 (клавиатура)
=8000               vv55_port_a      equ 8000h            ; Порт A клавиатуры (шина сканирования)
=8001               vv55_port_b      equ 8001h            ; Порт B клавиатуры (состояние клавиш)
=8002               vv55_port_c      equ 8002h            ; Порт C клавиатуры (вспомогательные клавиши, магнитофон)
=8003               vv55_ctrl        equ 8003h            ; Регистр управляющего слова клавиатуры

                    ; ППА К580ВВ55 D14 (дополнительный, для ROM-диска)
=A000               vv55_d14_port_a  equ 0A000h           ; Порт A D14 (шина данных ROM-диска)
=A001               vv55_d14_port_b  equ 0A001h           ; Порт B D14 (мл. байт адреса ROM-диска)
=A002               vv55_d14_port_c  equ 0A002h           ; Порт C D14 (ст. байт адреса ROM-диска)
=A003               vv55_d14_ctrl    equ 0A003h           ; Регистр управляющего слова D14

                    ; Контроллер ЭЛТ К580ВГ75
=C000               vg75_params      equ 0C000h           ; Регистр параметров
=C001               vg75_cmd_reg     equ 0C001h           ; Регистр команд (запись) / состояния (чтение)

                    ; Контроллер ПДП К580ВТ57
=E004               vt57_ch2_addr    equ 0E004h           ; Регистр адреса канала 2
=E005               vt57_ch2_ctrl    equ 0E005h           ; Регистр управления канала 2
=E008               vt57_mode        equ 0E008h           ; Регистр режима контроллера ПДП

                    ;----------------------------------------------------------------------------
                    ; Стандартные константы
                    ;----------------------------------------------------------------------------
=0924               video_mem_size   equ 78*30            ; Количество байт в видео ОЗУ (2340)
=0030               rst_6_addr       equ 30h              ; Адрес перехода по команде RST 6
=00E6               sync_byte        equ 0E6h             ; Синхробайт для чтения с магнитофона
=002A               const_read       equ 2Ah              ; Стандартная константа чтения с магнитофона
=001D               const_write      equ 1Dh              ; Стандартная константа записи на магнитофон
=5003               kb_click         equ 5003h            ; Щелчок от нажатия клавиши (B=50h, C=03h)
=05F0               beep             equ 5F0h             ; Звуковой сигнал (B=05h, C=F0h)
=00E0               first_kb_delay   equ 224              ; Начальная задержка автоповтора клавиатуры
=0040               regular_kb_delay equ 64               ; Стандартная задержка автоповтора клавиатуры
=0015               bounce           equ 21               ; Задержка для устранения дребезга контактов

                    ;----------------------------------------------------------------------------
                    ; Область переменных Монитора (для ОЗУ 32кБ)
                    ;----------------------------------------------------------------------------
=7600               monitor_area     equ 7600h

=75FF               memory_top       equ monitor_area-1    ; 75FFh - Верхняя граница свободной памяти
=7600               cursor_addr      equ monitor_area+0    ; 7600h - Адрес знакоместа курсора в видео ОЗУ
=7602               cursor_xy        equ monitor_area+2    ; 7602h - Координаты курсора (ст. - Y, мл. - X)
=7604               ap2_seq          equ monitor_area+4    ; 7604h - Номер байта в АР2-последовательности
=7605               pressed_key      equ monitor_area+5    ; 7605h - FF - клавиша нажата, 0 - не нажата
=7606               ruslat_flag      equ monitor_area+6    ; 7606h - Флаг РУС/ЛАТ: 0 - лат, FF - рус
=7609               keyboard_repeat  equ monitor_area+9    ; 7609h - Мл. байт - код клавиши, ст. - счетчик автоповтора
=760B               released         equ monitor_area+0Bh  ; 760Bh - Признак, что клавиша была отпущена
=760D               temp_sp          equ monitor_area+0Dh  ; 760Dh - Временное хранение указателя стека
=7614               pc_storage       equ monitor_area+14h  ; 7614h - Хранение адреса останова (PC)
=7616               hl_storage       equ monitor_area+16h  ; 7616h - Хранение HL
=7618               bc_storage       equ monitor_area+18h  ; 7618h - Хранение BC
=761A               de_storage       equ monitor_area+1Ah  ; 761Ah - Хранение DE
=761C               sp_storage       equ monitor_area+1Ch  ; 761Ch - Хранение SP
=761E               af_storage       equ monitor_area+1Eh  ; 761Eh - Хранение A и PSW
=7623               stop_addr        equ monitor_area+23h  ; 7623h - Адрес останова отлаживаемой программы
=7625               stop_addr_value  equ monitor_area+25h  ; 7625h - Байт по адресу останова (сохраненный)
=7626               jump_to_go       equ monitor_area+26h  ; 7626h - Команда JMP (0C3h) для директивы G
=7627               cmd_parameter_1  equ monitor_area+27h  ; 7627h - Первый параметр команды
=7629               cmd_parameter_2  equ monitor_area+29h  ; 7629h - Второй параметр команды
=762B               cmd_parameter_3  equ monitor_area+2Bh  ; 762Bh - Третий параметр команды
=762D               param_2_present  equ monitor_area+2Dh  ; 762Dh - Второй параметр присутствует = FF
=762E               tape_polarity    equ monitor_area+2Eh  ; 762Eh - Полярность входных данных с магнитофона
=762F               tape_read_const  equ monitor_area+2Fh  ; 762Fh - Константа чтения с магнитофона
=7630               tape_write_const equ monitor_area+30h  ; 7630h - Константа записи на магнитофон
=7631               memory_limit     equ monitor_area+31h  ; 7631h - Верхний адрес свободной памяти
=7633               kbd_buf          equ monitor_area+33h  ; 7633h - Буфер клавиатуры (32 байта)
=765F               monitor_area_end equ monitor_area+5Fh  ; 765Fh - Конец области переменных
=76CF               stack_bottom     equ monitor_area+0CFh ; 76CFh - Дно стека
=76D0               video_memory     equ monitor_area+0D0h ; 76D0h - Начало видеопамяти
=7FF4               video_memory_end equ video_memory+video_mem_size ; 7FF4h - Конец видеопамяти

                    ; Этот адрес используется как обращение к расширению ПЗУ Монитора,
                    ; которое так и не было реализовано. Из-за упрощенного декодирования
                    ; адресов ПЗУ в реальном Радио-86РК с ПЗУ 2кБ переход происходит
                    ; на "холодный" старт Монитора (start).
                    ; Расширять ПЗУ можно вниз, вплоть до адреса 0E000h (8кБ)
                    ; без каких-либо схемотехнических изменений.
=F000               ext_f000         equ 0F000h

                    ;============================================================================
F800:                                org 0F800h
                    ;============================================================================

                    ;----------------------------------------------------------------------------
                    ; "Холодный" старт программы Монитор (F800h)
                    ;----------------------------------------------------------------------------
F800:               start:                                   ; F800
F800: C3 36 F8                       jmp     entry_start

                    ;----------------------------------------------------------------------------
                    ; Таблица стандартных подпрограмм Монитора
                    ;----------------------------------------------------------------------------
F803: C3 63 FE      getc:            jmp     entry_getc      ; F803 - ввод символа с клавиатуры
F806: C3 98 FB      inpb:            jmp     entry_inpb      ; F806 - ввод байта с магнитофона
F809: C3 BA FC      putc:            jmp     entry_putc      ; F809 - вывод символа на экран
F80C: C3 46 FC      outb:            jmp     entry_outb      ; F80C - вывод байта на магнитофон
F80F: C3 BA FC      temp:            jmp     entry_putc      ; F80F - резерв (дублирует putc)
F812: C3 01 FE      kbhit:           jmp     entry_kbhit     ; F812 - опрос состояния клавиатуры
F815: C3 A5 FC      hexb:            jmp     entry_hexb      ; F815 - вывод байта в hex на экран
F818: C3 22 F9      puts:            jmp     entry_puts      ; F818 - вывод строки на экран
F81B: C3 72 FE      scan_kbd:        jmp     entry_scan_kbd  ; F81B - сканирование клавиатуры
F81E: C3 7B FA      getxy:           jmp     entry_getxy     ; F81E - получить координаты курсора
F821: C3 7F FA      curc:            jmp     entry_curc      ; F821 - получить символ под курсором
F824: C3 B6 FA      inpblock:        jmp     entry_inpblock  ; F824 - ввод блока с магнитофона
F827: C3 49 FB      outblock:        jmp     entry_outblock  ; F827 - вывод блока на магнитофон
F82A: C3 16 FB      chksum:          jmp     entry_chksum    ; F82A - подсчет контрольной суммы
F82D: C3 CE FA      video:           jmp     entry_video     ; F82D - настройка видеоконтроллера
F830: C3 52 FF      getlim:          jmp     entry_getlim    ; F830 - получить границу памяти
F833: C3 56 FF      setlim:          jmp     entry_setlim    ; F833 - установить границу памяти

                    ;============================================================================
                    ; Инициализация компьютера (Холодный старт)
                    ;============================================================================
F836:               entry_start:                             ; F836
                    ; Настройка ППА клавиатуры D20: порт A - вывод, порт B - ввод,
                    ; C0-C4 - вывод, C5-C7 - ввод
F836: 3E 8A                          mvi     a, 8Ah
F838: 32 03 80                       sta     vv55_ctrl

                    ; Настраиваем указатель стека
F83B: 31 CF 76                       lxi     sp, stack_bottom

                    ; Настраиваем отображение видеопамяти на экране.
                    ; Это нужно делать в первую очередь, чтобы начать регенерацию ОЗУ
                    ; после сброса.
F83E: CD CE FA                       call    entry_video

                    ; Обнуляем массив служебных ячеек Монитора
F841: 21 00 76                       lxi     h, monitor_area
F844: 11 5F 76                       lxi     d, monitor_area_end
F847: 0E 00                          mvi     c, 0
F849: CD ED F9                       call    cmd_f   ; заполнить 'c' от hl до de

F84C: 21 CF 76                       lxi     h, stack_bottom
F84F: 22 1C 76                       shld    sp_storage

                    ; Выводим на экран начальное сообщение "РАДИО-86РК"
F852: 21 5A FF                       lxi     h, radio_prompt
F855: CD 22 F9                       call    entry_puts

                    ; Повторно настраиваем видеоконтроллер
F858: CD CE FA                       call    entry_video

                    ; Устанавливаем верхнюю границу свободной памяти
F85B: 21 FF 75                       lxi     h, memory_top
F85E: 22 31 76                       shld    memory_limit

                    ; Устанавливаем константы по умолчанию для чтения и записи на магнитофон
                    ; (L=2Ah - чтение, H=1Dh - запись, SHLD сохраняет L первым)
F861: 21 2A 1D                       lxi     h, const_write * 256 + const_read
F864: 22 2F 76                       shld    tape_read_const

                    ; Установка кода команды JMP для директивы G
F867: 3E C3                          mvi     a, 0C3h
F869: 32 26 76                       sta     jump_to_go

                    ;============================================================================
                    ; Выход на промт (Горячий старт)
                    ;============================================================================
F86C:               prompt_loop:                             ; F86C
F86C: 31 CF 76                       lxi     sp, stack_bottom

F86F: 21 66 FF                       lxi     h, prompt
F872: CD 22 F9                       call    entry_puts

                    ; После выхода из entry_puts в A всегда 0
F875: 32 02 80                       sta     vv55_port_c      ; Все 0 в порт C клавиатуры
F878: 3D                             dcr     a                ; A = FFh
F879: 32 02 A0                       sta     vv55_d14_port_c  ; Все 1 в порт C дополнительного ППА

                    ;============================================================================
                    ; Консольный процессор Монитора - ввод и выполнение команд
                    ;============================================================================
F87C: CD EE F8                       call    input_string
F87F: 21 6C F8                       lxi     h, prompt_loop
F882: E5                             push    h               ; Адрес возврата в стеке
F883: 21 33 76                       lxi     h, kbd_buf
F886: 7E                             mov     a, m            ; Первый символ команды

                    ; Команды без параметров
F887: FE 58                          cpi     'X'             ; Просмотр/изменение регистров
F889: CA D3 FF                       jz      print_regs
F88C: FE 55                          cpi     'U'             ; Резервная команда -> расширение ПЗУ
F88E: CA 00 F0                       jz      ext_f000

                    ; Получаем 3 параметра команды: 1 -> HL, 2 -> DE, 3 -> BC
F891: F5                             push    psw
F892: CD 2C F9                       call    parse_param
F895: 2A 2B 76                       lhld    cmd_parameter_3
F898: 4D                             mov     c, l
F899: 44                             mov     b, h
F89A: 2A 29 76                       lhld    cmd_parameter_2
F89D: EB                             xchg
F89E: 2A 27 76                       lhld    cmd_parameter_1
F8A1: F1                             pop     psw

                    ; Команды с параметрами
F8A2: FE 44                          cpi     'D'             ; dump - дамп памяти
F8A4: CA C5 F9                       jz      cmd_d
F8A7: FE 43                          cpi     'C'             ; compare - сравнение областей памяти
F8A9: CA D7 F9                       jz      cmd_c
F8AC: FE 46                          cpi     'F'             ; fill - заполнение области памяти
F8AE: CA ED F9                       jz      cmd_f
F8B1: FE 53                          cpi     'S'             ; search - поиск байта в памяти
F8B3: CA F4 F9                       jz      cmd_s
F8B6: FE 54                          cpi     'T'             ; transfer - пересылка области памяти
F8B8: CA FF F9                       jz      cmd_t
F8BB: FE 4D                          cpi     'M'             ; modify - изменение содержимого памяти
F8BD: CA 26 FA                       jz      cmd_m
F8C0: FE 47                          cpi     'G'             ; go - запуск программы
F8C2: CA 3F FA                       jz      cmd_g
F8C5: FE 49                          cpi     'I'             ; input - загрузка с магнитофона
F8C7: CA 86 FA                       jz      cmd_i
F8CA: FE 4F                          cpi     'O'             ; output - запись на магнитофон
F8CC: CA 2D FB                       jz      cmd_o
F8CF: FE 4C                          cpi     'L'             ; literal - дамп в символьном виде
F8D1: CA 08 FA                       jz      cmd_l
F8D4: FE 52                          cpi     'R'             ; read - загрузка из ROM-диска
F8D6: CA 68 FA                       jz      cmd_r

                    ; Нераспознанная команда -> переход на расширение ПЗУ
F8D9: C3 00 F0                       jmp     ext_f000

                    ;----------------------------------------------------------------------------
                    ; Удаление предыдущего символа в буфере ввода
                    ;----------------------------------------------------------------------------
F8DC:               back_kbd_buf:                            ; F8DC
F8DC: 3E 33                          mvi     a, kbd_buf & 0FFh
F8DE: BD                             cmp     l               ; Если это первый символ,
F8DF: CA F1 F8                       jz      input_next      ; то ничего не делать
F8E2: E5                             push    h
F8E3: 21 9E FF                       lxi     h, back_clear   ; Затереть предыдущий символ на экране
F8E6: CD 22 F9                       call    entry_puts
F8E9: E1                             pop     h
F8EA: 2B                             dcx     h
F8EB: C3 F3 F8                       jmp     kbd_buf_loop

                    ;----------------------------------------------------------------------------
                    ; Ввод строки с клавиатуры.
                    ; Вводим максимум 31 символ в буфер клавиатуры.
                    ; Особо обрабатываемые клавиши:
                    ;   [<-] и [ЗБ] - удаление последнего символа
                    ;   [.]         - выход на промт
                    ;   [ВК]        - успешный возврат из п/п
                    ;----------------------------------------------------------------------------
F8EE:               input_string:                            ; F8EE
F8EE: 21 33 76                       lxi     h, kbd_buf

F8F1:               input_next:                              ; F8F1
F8F1: 06 00                          mvi     b, 0            ; Признак: ничего не введено

F8F3:               kbd_buf_loop:                            ; F8F3
F8F3: CD 63 FE                       call    entry_getc

F8F6: FE 08                          cpi     8               ; Клавиша [<-]?
F8F8: CA DC F8                       jz      back_kbd_buf
F8FB: FE 7F                          cpi     7Fh             ; Клавиша [ЗБ]?
F8FD: CA DC F8                       jz      back_kbd_buf
F900: C4 B9 FC                       cnz     putc_from_a     ; Вывести символ на экран
F903: 77                             mov     m, a            ; Сохранить в буфере
F904: FE 0D                          cpi     0Dh             ; Клавиша [ВК]?
F906: CA 1A F9                       jz      input_string_end
F909: FE 2E                          cpi     '.'             ; Точка -> выход на промт
F90B: CA 6C F8                       jz      prompt_loop
F90E: 06 FF                          mvi     b, 0FFh         ; Признак: что-то введено
F910: 3E 52                          mvi     a, (kbd_buf+1Fh) & 0FFh
F912: BD                             cmp     l               ; Буфер полон?
F913: CA AE FA                       jz      print_error     ; Если полон, то ошибка (?)
F916: 23                             inx     h
F917: C3 F3 F8                       jmp     kbd_buf_loop

F91A:               input_string_end:                        ; F91A
F91A: 78                             mov     a, b            ; Флаг: CF=1 если что-то введено
F91B: 17                             ral
F91C: 11 33 76                       lxi     d, kbd_buf
F91F: 06 00                          mvi     b, 0
F921: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Вывод строки на экран.
                    ; Указатель на начало строки в HL. Строка завершается нулевым байтом.
                    ;----------------------------------------------------------------------------
F922:               entry_puts:                              ; F922
F922: 7E                             mov     a, m
F923: A7                             ana     a               ; Нулевой байт?
F924: C8                             rz                      ; Если да, то выход
F925: CD B9 FC                       call    putc_from_a
F928: 23                             inx     h
F929: C3 22 F9                       jmp     entry_puts

                    ;----------------------------------------------------------------------------
                    ; Анализ параметров команд Монитора.
                    ; Разбирает до 3 параметров, разделенных запятыми.
                    ;----------------------------------------------------------------------------
F92C:               parse_param:                                    ; F92C
F92C: 21 27 76                       lxi     h, cmd_parameter_1     ; Обнуляем область параметров
F92F: 11 2D 76                       lxi     d, cmd_parameter_1+2*3
F932: 0E 00                          mvi     c, 0
F934: CD ED F9                       call    cmd_f
F937: 11 34 76                       lxi     d, kbd_buf+1           ; Указатель на второй символ
F93A: CD 5A F9                       call    parse_hex              ; Получаем первый параметр
F93D: 22 27 76                       shld    cmd_parameter_1
F940: 22 29 76                       shld    cmd_parameter_2        ; По умолчанию = первому
F943: D8                             rc                             ; Если больше ничего, выходим

                    ; Признак наличия второго параметра (так как он может быть равен 0)
                    ; Здесь вводится признак наличия второго параметра.
                    ; Поскольку невведенные параметры у нас = 0, то признак указывает,
                    ; что второй параметр введен и возможно равен нулю
F944: 3E FF                          mvi     a, 0FFh
F946: 32 2D 76                       sta     param_2_present
F949: CD 5A F9                       call    parse_hex
F94C: 22 29 76                       shld    cmd_parameter_2
F94F: D8                             rc

F950: CD 5A F9                       call    parse_hex
F953: 22 2B 76                       shld    cmd_parameter_3
F956: D8                             rc

F957: C3 AE FA                       jmp     print_error       ; Лишние параметры -> ошибка

                    ;----------------------------------------------------------------------------
                    ; Обработка строки с hex-числом (параметром), на которую указывает DE.
                    ; Результат в HL. CF=1 если параметра не было (встретился ВК).
                    ;----------------------------------------------------------------------------
F95A:               parse_hex:                               ; F95A
F95A: 21 00 00                       lxi     h, 0

F95D:               parse_hex_loop:                          ; F95D
F95D: 1A                             ldax    d
F95E: 13                             inx     d
F95F: FE 0D                          cpi     0Dh             ; [ВК] - конец строки
F961: CA 8E F9                       jz      parse_hex_end
F964: FE 2C                          cpi     ','             ; Запятая - разделитель параметров
F966: C8                             rz
F967: FE 20                          cpi     ' '             ; Пробелы игнорируются
F969: CA 5D F9                       jz      parse_hex_loop
F96C: D6 30                          sui     '0'             ; Получаем цифру из кода символа
F96E: FA AE FA                       jm      print_error     ; Код < 30h -> ошибка
F971: FE 0A                          cpi     0Ah             ; Цифра 0-9?
F973: FA 82 F9                       jm      parse_hex_char
F976: FE 11                          cpi     11h             ; Код < 41h (A) -> ошибка
F978: FA AE FA                       jm      print_error
F97B: FE 17                          cpi     17h             ; Код > 46h (F) -> ошибка
F97D: F2 AE FA                       jp      print_error
F980: D6 07                          sui     7               ; Корректировка для цифр A-F

                    ; Добавляем очередную hex-цифру в число
F982:               parse_hex_char:                          ; F982
F982: 4F                             mov     c, a
F983: 29                             dad     h               ; Число * 16
F984: 29                             dad     h
F985: 29                             dad     h
F986: 29                             dad     h
F987: DA AE FA                       jc      print_error     ; Переполнение -> ошибка
F98A: 09                             dad     b               ; Прибавляем очередную цифру
F98B: C3 5D F9                       jmp     parse_hex_loop

                    ; Выход с признаком CF=1 (параметра не было)
F98E:               parse_hex_end:                           ; F98E
F98E: 37                             stc
F98F: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Сравнение регистровых пар HL и DE.
                    ; Если равны, устанавливается флаг Z.
                    ;----------------------------------------------------------------------------
F990:               cmp_hl_de:                               ; F990
F990: 7C                             mov     a, h
F991: BA                             cmp     d
F992: C0                             rnz
F993: 7D                             mov     a, l
F994: BB                             cmp     e
F995: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Проверка на окончание адреса + сканирование на нажатие [F4].
                    ;----------------------------------------------------------------------------
F996:               end_of_addr_or_f4:                       ; F996
F996: CD A4 F9                       call    check_press_f4

                    ;----------------------------------------------------------------------------
                    ; Инкремент текущего адреса с проверкой на конец.
                    ; Сравнивает HL с DE. Если равны - удаляет адрес возврата и выходит
                    ; к предыдущему вызывающему. Если не равны - инкремент HL.
                    ;----------------------------------------------------------------------------
F999:               cmp_hl_de_loop:                          ; F999
F999: CD 90 F9                       call    cmp_hl_de
F99C: C2 A2 F9                       jnz     cmp_hl_de_end

F99F:               cmp_hl_de_ret:                           ; F99F
F99F: 33                             inx     sp              ; Удаляем текущий адрес возврата
F9A0: 33                             inx     sp
F9A1: C9                             ret

F9A2:               cmp_hl_de_end:                           ; F9A2
F9A2: 23                             inx     h
F9A3: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Проверка на нажатие клавиши [F4] (код 3) для прерывания команды.
                    ; Клавиша [РУС/ЛАТ] приостанавливает вывод на экран (удержание).
                    ; [F4] -> выход на промт со знаком вопроса.
                    ; Подпрограмма применяется для выхода из затянувшейся по времени команды.
                    ; Так же можно использовать для приостановки вывода на экран удержание
                    ; клавиши [РУС/ЛАТ], поскольку она срабатывает при отпускании.
                    ; Если клавиша [F4] не нажата, происходит просто выход из подпрограммы.
                    ; Если нажата, то выход на промт с выдачей знака вопроса.
                    ;----------------------------------------------------------------------------
F9A4:               check_press_f4:                          ; F9A4
F9A4: CD 72 FE                       call    entry_scan_kbd
F9A7: FE 03                          cpi     3               ; Код клавиши [F4]
F9A9: C0                             rnz
F9AA: CD CE FA                       call    entry_video     ; Восстанавливаем видео
F9AD: C3 AE FA                       jmp     print_error

                    ;----------------------------------------------------------------------------
                    ; Переход на новую строку с отступом в 4 символа для вывода адреса.
                    ;----------------------------------------------------------------------------
F9B0:               print_next_line_prefix:                  ; F9B0
F9B0: E5                             push    h
F9B1: 21 6C FF                       lxi     h, next_line_prefix
F9B4: CD 22 F9                       call    entry_puts
F9B7: E1                             pop     h
F9B8: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Вывод байта [HL] на экран в hex + пробел
                    ;----------------------------------------------------------------------------
F9B9:               print_hex_mem_and_space:                  ; F9B9
F9B9: 7E                             mov     a, m

                    ; Вывод байта из A на экран в hex + пробел
F9BA:               print_hex_byte_and_space:                 ; F9BA
F9BA: C5                             push    b
F9BB: CD A5 FC                       call    entry_hexb
F9BE: 3E 20                          mvi     a, ' '
F9C0: CD B9 FC                       call    putc_from_a
F9C3: C1                             pop     b
F9C4: C9                             ret

                    ;============================================================================
                    ; Команда D (Dump). Вывод дампа памяти в hex.
                    ; По 16 байт в строке. В начале строки - адрес первой ячейки.
                    ; Адрес строки округляется до 0 в младшей hex-цифре.
                    ;============================================================================
F9C5:               cmd_d:                                   ; F9C5
F9C5: CD 78 FB                       call    print_addr_from_hl

F9C8:               cmd_d_loop:                              ; F9C8
F9C8: CD B9 F9                       call    print_hex_mem_and_space
F9CB: CD 96 F9                       call    end_of_addr_or_f4
F9CE: 7D                             mov     a, l
F9CF: E6 0F                          ani     0Fh             ; Граница 16 байт?
F9D1: CA C5 F9                       jz      cmd_d           ; Да -> новая строка с адресом
F9D4: C3 C8 F9                       jmp     cmd_d_loop

                    ;============================================================================
                    ; Команда C (Compare). Сравнение двух областей памяти.
                    ; Сравнивает [HL] с [BC], выводит только различающиеся байты.
                    ; В строке: адрес, значение из первой области, значение из второй.
                    ;============================================================================
F9D7:               cmd_c:                                   ; F9D7
F9D7: 0A                             ldax    b
F9D8: BE                             cmp     m
F9D9: CA E6 F9                       jz      cmd_c_equal     ; Байты равны - пропускаем
F9DC: CD 78 FB                       call    print_addr_from_hl
F9DF: CD B9 F9                       call    print_hex_mem_and_space
F9E2: 0A                             ldax    b
F9E3: CD BA F9                       call    print_hex_byte_and_space

F9E6:               cmd_c_equal:                         ; F9E6
F9E6: 03                             inx     b
F9E7: CD 96 F9                       call    end_of_addr_or_f4
F9EA: C3 D7 F9                       jmp     cmd_c

                    ;============================================================================
                    ; Команда F (Fill). Заполнение области памяти.
                    ; Заполняет память от HL до DE байтом из C (третий параметр).
                    ;============================================================================
F9ED:               cmd_f:                           ; F9ED
F9ED: 71                             mov     m, c
F9EE: CD 99 F9                       call    cmp_hl_de_loop
F9F1: C3 ED F9                       jmp     cmd_f

                    ;============================================================================
                    ; Команда S (Search). Поиск байта в памяти.
                    ; Ищет байт из C в области от HL до DE.
                    ; Выводит адреса найденных совпадений.
                    ;============================================================================
F9F4:               cmd_s:                           ; F9F4
F9F4: 79                             mov     a, c
F9F5: BE                             cmp     m
F9F6: CC 78 FB                       cz      print_addr_from_hl
F9F9: CD 96 F9                       call    end_of_addr_or_f4
F9FC: C3 F4 F9                       jmp     cmd_s

                    ;============================================================================
                    ; Команда T (Transfer). Пересылка области памяти.
                    ; Пересылает байты из [HL..DE] в область, начиная с [BC].
                    ;============================================================================
F9FF:               cmd_t:                                   ; F9FF
F9FF: 7E                             mov     a, m
FA00: 02                             stax    b
FA01: 03                             inx     b
FA02: CD 99 F9                       call    cmp_hl_de_loop
FA05: C3 FF F9                       jmp     cmd_t

                    ;============================================================================
                    ; Команда L (Literal). Вывод содержимого памяти в символьном виде.
                    ; По 16 символов в строке. Непечатные символы заменяются точками.
                    ;============================================================================
FA08:               cmd_l:                                   ; FA08
FA08: CD 78 FB                       call    print_addr_from_hl

FA0B:               cmd_l_loop:                              ; FA0B
FA0B: 7E                             mov     a, m
FA0C: B7                             ora     a               ; Код > 7Fh?
FA0D: FA 15 FA                       jm      cmd_l_period    ; Да -> точка
FA10: FE 20                          cpi     ' '             ; Код < 20h (управляющий)?
FA12: D2 17 FA                       jnc     cmd_l_char      ; Нет -> выводим как есть

FA15:               cmd_l_period:                            ; FA15
FA15: 3E 2E                          mvi     a, '.'

FA17:               cmd_l_char:                              ; FA17
FA17: CD B9 FC                       call    putc_from_a
FA1A: CD 96 F9                       call    end_of_addr_or_f4
FA1D: 7D                             mov     a, l
FA1E: E6 0F                          ani     0Fh
FA20: CA 08 FA                       jz      cmd_l
FA23: C3 0B FA                       jmp     cmd_l_loop

                    ;============================================================================
                    ; Команда M (Modify). Изменение содержимого памяти.
                    ; Выводит адрес и содержимое ячейки, ожидает ввод нового значения.
                    ; [ВК] - перейти к следующей, [.] - выход из команды.
                    ;============================================================================
FA26:               cmd_m:                                    ; FA26
FA26: CD 78 FB                       call    print_addr_from_hl
FA29: CD B9 F9                       call    print_hex_mem_and_space
FA2C: E5                             push    h
FA2D: CD EE F8                       call    input_string
FA30: E1                             pop     h
FA31: D2 3B FA                       jnc     cmd_m_next       ; Ничего не введено -> следующий адрес

FA34: E5                             push    h
FA35: CD 5A F9                       call    parse_hex        ; Получаем новое значение в HL
FA38: 7D                             mov     a, l
FA39: E1                             pop     h
FA3A: 77                             mov     m, a             ; Записываем в память

FA3B:               cmd_m_next:                               ; FA3B
FA3B: 23                             inx     h
FA3C: C3 26 FA                       jmp     cmd_m

                    ;============================================================================
                    ; Команда G (Go). Запуск программы.
                    ; 1-й параметр: адрес старта.
                    ; 2-й параметр (необязательный): адрес останова.
                    ; Если адрес останова указан, по нему записывается RST 6 (F7h),
                    ; а по адресу 0030h - JMP return_address. После останова регистры
                    ; сохраняются в служебных ячейках (доступны по команде X).
                    ;============================================================================
FA3F:               cmd_g:                                   ; FA3F
FA3F: CD 90 F9                       call    cmp_hl_de       ; Указан ли адрес останова?
FA42: CA 5A FA                       jz      cmd_g_run       ; Нет -> сразу запуск

                    ; Настройка механизма останова через адрес 0030h
FA45: EB                             xchg
FA46: 22 23 76                       shld    stop_addr       ; Сохраняем адрес останова
FA49: 7E                             mov     a, m
FA4A: 32 25 76                       sta     stop_addr_value ; Сохраняем байт по этому адресу
FA4D: 36 F7                          mvi     m, 0F7h         ; RST 6 по адресу останова
FA4F: 3E C3                          mvi     a, 0C3h         ; Команда JMP
FA51: 32 30 00                       sta     rst_6_addr      ; по адресу 0030h
FA54: 21 A2 FF                       lxi     h, return_address
FA57: 22 31 00                       shld    rst_6_addr+1    ; Адрес возврата

                    ; Загрузка регистров из служебных ячеек и запуск программы
FA5A:               cmd_g_run:                               ; FA5A
FA5A: 31 18 76                       lxi     sp, bc_storage
FA5D: C1                             pop     b
FA5E: D1                             pop     d
FA5F: E1                             pop     h
FA60: F1                             pop     psw
FA61: F9                             sphl                    ; Загружаем SP
FA62: 2A 16 76                       lhld    hl_storage
FA65: C3 26 76                       jmp     jump_to_go      ; JMP на адрес старта

                    ;============================================================================
                    ; Команда R (Read). Загрузка из ROM-диска (ПЗУ через доп. ППА D14).
                    ; Шина данных -> порт A, шина адреса -> порты B и C.
                    ; 1-й параметр: начальный адрес в ОЗУ, 2-й: конечный, 3-й: адрес в ПЗУ.
                    ;============================================================================
FA68:               cmd_r:                           ; FA68
FA68: 3E 90                          mvi     a, 90h          ; Порт A - ввод, B и C - вывод
FA6A: 32 03 A0                       sta     vv55_d14_ctrl

FA6D:               cmd_r_loop:                              ; FA6D
FA6D: 22 01 A0                       shld    vv55_d14_port_b ; Адрес в ПЗУ (мл. в B, ст. в C)
FA70: 3A 00 A0                       lda     vv55_d14_port_a ; Читаем байт
FA73: 02                             stax    b               ; Сохраняем в ОЗУ
FA74: 03                             inx     b               ; Перейти к след. адресу ОЗУ
FA75: CD 99 F9                       call    cmp_hl_de_loop  ; Проверка на конец
FA78: C3 6D FA                       jmp     cmd_r_loop

                    ;----------------------------------------------------------------------------
                    ; Получить координаты курсора в HL (H=Y, L=X)
                    ;----------------------------------------------------------------------------
FA7B:               entry_getxy:                             ; FA7B
FA7B: 2A 02 76                       lhld    cursor_xy
FA7E: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Получить символ с экрана по адресу курсора в A
                    ;----------------------------------------------------------------------------
FA7F:               entry_curc:                              ; FA7F
FA7F: E5                             push    h
FA80: 2A 00 76                       lhld    cursor_addr
FA83: 7E                             mov     a, m
FA84: E1                             pop     h
FA85: C9                             ret

                    ;============================================================================
                    ; Команда I (Input). Загрузка блока данных с магнитофона.
                    ; 1-й параметр: смещение относительно адреса на ленте.
                    ; 2-й параметр (необязательный): новая константа чтения.
                    ;============================================================================
FA86:               cmd_i:                                    ; FA86
FA86: 3A 2D 76                       lda     param_2_present
FA89: B7                             ora     a
FA8A: CA 91 FA                       jz      cmd_i_cr
FA8D: 7B                             mov     a, e
FA8E: 32 2F 76                       sta     tape_read_const  ; Новая константа чтения

FA91:               cmd_i_cr:                                   ; FA91
FA91: CD B6 FA                       call    entry_inpblock     ; Читаем блок с магнитофона
FA94: CD 78 FB                       call    print_addr_from_hl ; Выводим адрес начала
FA97: EB                             xchg
FA98: CD 78 FB                       call    print_addr_from_hl ; Выводим адрес конца
FA9B: EB                             xchg
FA9C: C5                             push    b
FA9D: CD 16 FB                       call    entry_chksum       ; Считаем контрольную сумму
FAA0: 60                             mov     h, b
FAA1: 69                             mov     l, c
FAA2: CD 78 FB                       call    print_addr_from_hl ; Выводим вычисленную КС
FAA5: D1                             pop     d                  ; Считанная КС
FAA6: CD 90 F9                       call    cmp_hl_de          ; Совпадают?
FAA9: C8                             rz                         ; Да -> выход
FAAA: EB                             xchg
FAAB: CD 78 FB                       call    print_addr_from_hl ; Нет -> выводим считанную КС

                    ;----------------------------------------------------------------------------
                    ; Выход из команды с ошибкой - знак вопроса и возврат на промт
                    ;----------------------------------------------------------------------------
FAAE:               print_error:                             ; FAAE
FAAE: 3E 3F                          mvi     a, '?'
FAB0: CD B9 FC                       call    putc_from_a
FAB3: C3 6C F8                       jmp     prompt_loop

                    ;============================================================================
                    ; Ввод блока данных с магнитофона.
                    ;   Вход:  HL - смещение
                    ;   Выход: HL - адрес начала, DE - адрес конца, BC - контрольная сумма
                    ; Структура блока на ленте:
                    ;   раккорд, синхробайт, начальный адрес, конечный адрес, данные,
                    ;   раккорд, синхробайт, контрольная сумма
                    ;============================================================================
FAB6:               entry_inpblock:                          ; FAB6
FAB6: 3E FF                          mvi     a, 0FFh         ; Признак поиска синхробайта
FAB8: CD FF FA                       call    input_bc        ; Вводим начальный адрес в BC
FABB: E5                             push    h
FABC: 09                             dad     b               ; Начальный адрес = адрес с ленты + смещение
FABD: EB                             xchg                    ; DE = начальный адрес
FABE: CD FD FA                       call    input_bc_no_sync ; Вводим конечный адрес в BC
FAC1: E1                             pop     h
FAC2: 09                             dad     b               ; Конечный адрес = адрес с ленты + смещение
FAC3: EB                             xchg                    ; HL = начальный, DE = конечный
FAC4: E5                             push    h
FAC5: CD 0A FB                       call    read_block      ; Вводим массив данных
FAC8: 3E FF                          mvi     a, 0FFh
FACA: CD FF FA                       call    input_bc        ; Вводим контрольную сумму в BC
FACD: E1                             pop     h

                    ;============================================================================
                    ; Настройка отображения на экране (видеоконтроллер ВГ75 + ПДП ВТ57)
                    ;============================================================================
FACE:               entry_video:                             ; FACE
FACE: E5                             push    h

                    ; Настраиваем контроллер ЭЛТ ВГ75
FACF: 21 01 C0                       lxi     h, vg75_cmd_reg
FAD2: 36 00                          mvi     m, 0            ; Команда Reset
FAD4: 2B                             dcx     h               ; Передаем параметры:
FAD5: 36 4D                          mvi     m, 4Dh          ; 78-1 = 77 символов в строке
FAD7: 36 1D                          mvi     m, 1Dh          ; 30-1 = 29 знакорядов в кадре
FAD9: 36 99                          mvi     m, 99h          ; Высота символа 10 строк, подчеркивание на 10-й
                                                             ; (10-1) << 4 | 9
                    ; Задаем режим отображения: 0 - без сдига номеров строк
                    ; Атрибуты поля: не прозрачные
                    ; Тип курсора: мигающее подчеркивание
                    ; Количество символов в строчном синхроимпульсе: 8 интервалов (6 мкс)
FADB: 36 93                          mvi     m, 93h          ; Режим: мигающее подчеркивание, 8 интервалов
                                                             ; (1 << 7) | (1 << 4) | ((8/2)-1)
FADD: 23                             inx     h
                    ; Команда "начать отображение":
                    ; интервал между запросами ПДП: 7 символов, 8 байт в пакете
FADE: 36 27                          mvi     m, 27h          ; (1 << 5) | (((7+1)/8) << 2) | 3
FAE0: 7E                             mov     a, m            ; Чтение статуса

                    ; Ожидаем начало кадра (бит IR в статусном регистре ВГ75)
                    ; Бит IR статусного регистра устанавливается после начала последнего знакоряда в кадре.
                    ; Как раз в это время и нужно загружать данные первого знакоряда на экране.
FAE1:               wait_frame_start:                        ; FAE1
FAE1: 7E                             mov     a, m
FAE2: E6 20                          ani     20h             ; Флаг IR
FAE4: CA E1 FA                       jz      wait_frame_start

                    ; Настраиваем канал 2 ПДП ВТ57 для пересылки видеоданных
                    ; Режим: чтение ОЗУ с автозагрузкой (регистры канала 3)
                    ; Для пересылки используется канал 2 в режиме чтения ОЗУ с автозагрузкой.
                    ; Для автозагрузки используются регистры канала 3.
                    ; После пересылки последнего байта экрана начальные данные ПДП (начальный
                    ; адрес и количество байт пересылки) снова автоматически загружаются в регистры
                    ; 2 канала и пересылка продолжается постоянно.
FAE7: 21 08 E0                       lxi     h, vt57_mode
FAEA: 36 80                          mvi     m, 80h                  ; Остановить ПДП, включить автозагрузку
                    ; Адрес начала пересылки: начало видео ОЗУ
FAEC: 2E 04                          mvi     l, vt57_ch2_addr & 0FFh ; 4
FAEE: 36 D0                          mvi     m, video_memory & 0FFh  ; 0Dh
FAF0: 36 76                          mvi     m, video_memory / 256   ; 76h
                    ; Количество байт пересылки и режим (запись в ОЗУ)
FAF2: 2C                             inr     l
FAF3: 36 23                          mvi     m, (video_mem_size-1) & 0FFh        ; 23h
FAF5: 36 49                          mvi     m, 40h | ((video_mem_size-1) / 256) ; 49h
                    ; Запускаем ПДП: автозагрузка, удлиненная запись, канал 2.
FAF7: 2E 08                          mvi     l, vt57_mode & 0FFh                 ; 8
FAF9: 36 A4                          mvi     m, 0A4h

FAFB: E1                             pop     h
FAFC: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Ввод 16-битного слова в BC с магнитофона (без синхробайта)
                    ;----------------------------------------------------------------------------
FAFD:               input_bc_no_sync:                        ; FAFD
FAFD: 3E 08                          mvi     a, 8            ; 8 бит, без поиска синхробайта

                    ; Ввод 16-битного слова в BC с магнитофона (с синхробайтом если A=FFh)
FAFF:               input_bc:                                ; FAFF
FAFF: CD 98 FB                       call    entry_inpb      ; Читаем старший байт
FB02: 47                             mov     b, a
FB03: 3E 08                          mvi     a, 8
FB05: CD 98 FB                       call    entry_inpb      ; Читаем младший байт
FB08: 4F                             mov     c, a
FB09: C9                             ret

                    ;----------------------------------------------------------------------------
                    ; Чтение массива данных с магнитофона.
                    ; HL - начальный адрес, DE - конечный адрес.
                    ;----------------------------------------------------------------------------
FB0A:               read_block:                              ; FB0A
FB0A: 3E 08                          mvi     a, 8            ; Без поиска синхробайта
FB0C: CD 98 FB                       call    entry_inpb
FB0F: 77                             mov     m, a            ; Сохраняем в память
FB10: CD 99 F9                       call    cmp_hl_de_loop
FB13: C3 0A FB                       jmp     read_block

                    ;============================================================================
                    ; Подсчет контрольной суммы.
                    ;   Вход:  HL - начальный адрес, DE - конечный адрес.
                    ;   Выход: BC - контрольная сумма.
                    ; Алгоритм:
                    ;   Младший байт (C): сумма всех байтов без учета переноса.
                    ;   Старший байт (B): сумма всех байтов (кроме последнего) + переносы из C.
                    ;============================================================================
FB16:               entry_chksum:                            ; FB16
FB16: 01 00 00                       lxi     b, 0

FB19:               checksum_loop:                           ; FB19
                    ; Обработка младшего байта
FB19: 7E                             mov     a, m
FB1A: 81                             add     c
FB1B: 4F                             mov     c, a
FB1C: F5                             push    psw             ; Сохраняем признак переноса
FB1D: CD 90 F9                       call    cmp_hl_de
FB20: CA 9F F9                       jz      cmp_hl_de_ret   ; Последний байт -> дост аем PSW и выходим
FB23: F1                             pop     psw
                    ; Обработка старшего байта
FB24: 78                             mov     a, b
FB25: 8E                             adc     m               ; Суммируем + перенос из младшего
FB26: 47                             mov     b, a
FB27: CD 99 F9                       call    cmp_hl_de_loop
